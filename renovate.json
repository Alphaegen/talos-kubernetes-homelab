{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "dependencyDashboardApproval": false,
  "customManagers": [
    {
      "customType": "regex",
      "description": "Update Helm chart versions annotated with '# renovate:' comments",
      "managerFilePatterns": [
        "/(^|/)gitops/.+\\.ya?ml$/"
      ],
      "matchStrings": [
        "#\\s*renovate:\\s*datasource=(?<datasource>\\S+)\\s+depName=(?<depName>\\S+)(?:\\s+registryUrl=(?<registryUrl>\\S+))?(?:\\s+versioning=(?<versioning>\\S+))?\\s*\\n\\s*version:\\s*[\"']?(?<currentValue>[^\"'\\s]+)[\"']?"
      ],
      "versioningTemplate": "{{#if versioning}}{{{versioning}}}{{else}}semver{{/if}}"
    }
  ],
  "helm-values": {
    "managerFilePatterns": [
      "/(^|/)gitops/infra-helm/values\\.ya?ml$/",
      "/(^|/)gitops/infra-custom/.+/values\\.ya?ml$/"
    ]
  },
  "kubernetes": {
    "managerFilePatterns": [
      "/(^|/)gitops/infra-custom/.+\\.ya?ml$/"
    ]
  },
  "packageRules": [
    {
      "description": "Parse LinuxServer application and image build versions",
      "matchDatasources": [
        "docker"
      ],
      "matchPackageNames": [
        "lscr.io/linuxserver/prowlarr",
        "lscr.io/linuxserver/radarr",
        "lscr.io/linuxserver/sonarr"
      ],
      "versioning": "regex:^(?<major>\\d+)\\.(?<minor>\\d+)\\.(?<patch>\\d+)\\.(?<build>\\d+)-ls(?<revision>\\d+)$"
    },
    {
      "description": "Parse qBittorrent Enhanced Edition release tags",
      "matchDatasources": [
        "docker"
      ],
      "matchPackageNames": [
        "sxyzy1016/qbittorrent-enhanced-edition"
      ],
      "versioning": "regex:^release-(?<major>\\d+)\\.(?<minor>\\d+)\\.(?<patch>\\d+)\\.(?<build>\\d+)$"
    },
    {
      "description": "Track both Go and Alpine versions in the builder image",
      "matchDatasources": [
        "docker"
      ],
      "matchPackageNames": [
        "golang"
      ],
      "versioning": "regex:^(?<major>\\d+)\\.(?<minor>\\d+)\\.(?<patch>\\d+)-alpine(?<build>\\d+)\\.(?<revision>\\d+)$"
    },
    {
      "description": "Group routine Helm updates while keeping major upgrades isolated",
      "matchDatasources": [
        "helm"
      ],
      "matchUpdateTypes": [
        "minor",
        "patch",
        "pin",
        "digest"
      ],
      "groupName": "helm chart updates"
    },
    {
      "description": "Group routine container updates while keeping major upgrades isolated",
      "matchDatasources": [
        "docker"
      ],
      "matchUpdateTypes": [
        "minor",
        "patch",
        "pin",
        "digest"
      ],
      "groupName": "container image updates"
    },
    {
      "description": "The private smoke image is released by this repository and is not anonymously queryable",
      "matchDatasources": [
        "docker"
      ],
      "matchPackageNames": [
        "ghcr.io/alphaegen/homelab-platform-smoke"
      ],
      "enabled": false
    }
  ],
  "rangeStrategy": "pin",
  "labels": [
    "dependencies",
    "gitops"
  ],
  "prConcurrentLimit": 10
}
